# SERVER CONFIG
PORT=4000
NODE_ENV=production

# SUPABASE CONNECTION (Get from Supabase Dashboard > Settings > Database)
# Example: postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# SUPABASE API (Optional for direct client use)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# JWT SECRET
JWT_SECRET="your-super-secret-key"

# AI/ML NODES (Optional internal secret)
NODE_AUTH_TOKEN="vision-aiot-secret-2026"
