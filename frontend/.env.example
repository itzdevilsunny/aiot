# ─── Vision AIoT Command Center ─── Environment Variables ───
# Copy this file to .env and fill in your values

# Gemini API Key (for Generative Report feature)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret (for auth, currently bypassed for public access)
JWT_SECRET=hackops-crew-secret-key-2026

# MongoDB Connection (auto-configured by Docker Compose)
# Vercel and MongoDB Atlas typically use MONGODB_URI
MONGODB_URI=mongodb://mongodb:27017/command_center
MONGO_URI=mongodb://mongodb:27017/command_center

# Backend Port
PORT=4000
